# Copy this file to .env and fill in your values.
# Never commit .env to version control.

# --- Anthropic ---
ANTHROPIC_API_KEY=sk-ant-...

# --- Microsoft Graph API ---
# From Azure portal > App registrations > your app > Overview / Certificates & secrets
MS_TENANT_ID=xxxxxxxx-xxxx-xxxx-xxxx-xxxxxxxxxxxx
MS_CLIENT_ID=xxxxxxxx-xxxx-xxxx-xxxx-xxxxxxxxxxxx
MS_CLIENT_SECRET=your_client_secret_value

# --- Teams DM delivery ---
# MS_RECIPIENT_EMAIL - who receives the Teams DM (e.g. your personal work account)
# MS_SENDER_EMAIL - service/bot account that appears as the "sender" in Teams
#                   Must be a real Azure AD user, different from MS_RECIPIENT_EMAIL.
#                   Example: support-agent@yourcompany.com
MS_RECIPIENT_EMAIL=you@yourcompany.com
MS_SENDER_EMAIL=support-agent@yourcompany.com

# --- WhatsApp Business API (Meta) ---
# From Meta Developer Console > your app > WhatsApp > API Setup
WHATSAPP_ACCESS_TOKEN=
WHATSAPP_PHONE_NUMBER_ID=
# A secret string you choose - must match what you enter in Meta's webhook config
VERIFY_TOKEN=
# Port the webhook Flask server listens on
WEBHOOK_PORT=5000

# --- MariaDB Database ---
DB_HOST=
DB_PORT=3306
DB_NAME=
DB_USER=
DB_PASSWORD=

# --- API Server ---
# Port for the WhatsApp upload microservice
API_PORT=5001

# Optional: Full API URL for upload_client.py (defaults to http://localhost:5001/upload-whatsapp-zip)
# In production, set this to your domain: https://yourdomain.com/upload-whatsapp-zip
API_URL=http://localhost:5001/upload-whatsapp-zip

# --- OpenAI (for Whisper transcription) ---
OPENAI_API_KEY=sk-proj-...

# --- Frappe Integration (Post-Processing) ---
# URL of your Frappe listener API endpoint (receives extracted tickets after processing)
# Uses Pulse Support Ticket doctype to store tickets
# Example: https://pm.lucrumerp.com/api/resource/Pulse Support Ticket
FRAPPE_LISTENER_URL=

# Frappe API Key-based authentication (recommended for production)
FRAPPE_API_KEY=
FRAPPE_API_SECRET=

# Optional: CSRF Token-based auth (if not using API Key)
# FRAPPE_CSRF_TOKEN=your_frappe_csrf_token_here
